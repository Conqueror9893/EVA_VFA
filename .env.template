## Frontend (Vite)
# No Bey managed agent is used in this project.

## LiveKit (server + agent runner)
LIVEKIT_URL=wss://<your-livekit-host>
LIVEKIT_API_KEY=<livekit-api-key>
LIVEKIT_API_SECRET=<livekit-api-secret>

## Beyond Presence (avatar video)
BEY_API_KEY=sk-...
BEY_AVATAR_ID=<beyond-presence-avatar-id>

## ElevenLabs (conversation + voice)
ELEVEN_API_KEY=...
ELEVEN_AGENT_ID=...
# Optional. Used only in classic (non-convai) mode
ELEVEN_VOICE_ID=
# Optional. Defaults to eleven_flash_v2_5
ELEVEN_TTS_MODEL=eleven_flash_v2_5
# Integration mode:
# - convai: use ELEVEN_AGENT_ID websocket flow (default)
# - classic: OpenAI STT/LLM + ElevenLabs TTS
ELEVEN_INTEGRATION_MODE=convai

## n8n (loan journey webhook — POST /api/n8n/loan)
N8N_LOAN_WEBHOOK_URL=https://eva-ramanik.app.n8n.cloud/webhook/ResponseFormat

## n8n (general user questions outside scripted journeys — POST /api/n8n/live-search)
N8N_LIVE_SEARCH_WEBHOOK_URL=https://eva-ramanik.app.n8n.cloud/webhook/hdfc_live_search

## Optional
OPENAI_API_KEY=sk-...
OPENAI_LLM_MODEL=gpt-4o-mini
SPEAK_TO_VIDEO_TEXT=
SPEAK_TO_VIDEO_ONLY=true
ELEVEN_DYNAMIC_NAME=friend
# ConvAI language mode: "auto" (default — agent uses language_detection tool to switch
# mid-call), or an ISO 639-1 code (hi, mr, en) to lock the agent to a single language.
# URL ?lang= and webhook variables override this.
# ELEVEN_AGENT_LANGUAGE=auto

